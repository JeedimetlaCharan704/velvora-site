# PayU Payment Gateway Credentials
# Get these from your PayU Merchant Dashboard: https://onboarding.payu.in/
# For testing: https://onboarding.payu.in/app/account/signup?民族文化&landing=true

PAYU_KEY=your_merchant_key_here
PAYU_SALT=your_merchant_salt_here

# Set to 'true' for test environment, 'false' for production
PAYU_TEST=true

# Server Configuration
PORT=3001
NODE_ENV=production

# Database (if using MongoDB)
MONGODB_URI=mongodb+srv://your_mongodb_connection_string

# Site URL (for PayU callback URLs)
SITE_URL=https://your-domain.vercel.app
