# =============================================
# VELVORA LUXURY - Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# PostgreSQL Configuration
PGHOST=localhost
PGPORT=5432
PGDATABASE=velvora
PGUSER=postgres
PGPASSWORD=your_postgres_password

# Email Configuration (Gmail SMTP)
# For Gmail: Enable 2FA and create an App Password
# Settings → Security → 2-Step Verification → App passwords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password
EMAIL_FROM="Velvora Luxury" <noreply@velvora.com>

# PayU Configuration (Get from PayU Merchant Dashboard)
# https://onboarding.payu.in/
PAYU_KEY=your_payu_merchant_key
PAYU_SALT=your_payu_salt_key
PAYU_TEST=true

# Server Port
PORT=3001
